<idea-plugin>
    <id>org.chisa.intellij</id>
    <name>Chisa</name>
    <version>0.1.0</version>
    <vendor>Chisa</vendor>

    <description><![CDATA[
    Language support for Chisa (.chisa files).
    Provides syntax highlighting, file type recognition, and basic structure view.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
                name="Chisa"
                implementationClass="org.chisa.intellij.ChisaFileType"
                fieldName="INSTANCE"
                language="Chisa"
                extensions="chisa"/>

        <lang.parserDefinition
                language="Chisa"
                implementationClass="org.chisa.intellij.parser.ChisaParserDefinition"/>

        <lang.syntaxHighlighterFactory
                language="Chisa"
                implementationClass="org.chisa.intellij.highlighting.ChisaSyntaxHighlighterFactory"/>

        <lang.psiStructureViewFactory
                language="Chisa"
                implementationClass="org.chisa.intellij.structure.ChisaStructureViewFactory"/>

        <lang.documentationProvider
                language="Chisa"
                implementationClass="org.chisa.intellij.documentation.ChisaDocumentationProvider"/>

        <completion.contributor
                language="Chisa"
                implementationClass="org.chisa.intellij.completion.ChisaCompletionContributor"/>

        <annotator
                language="Chisa"
                implementationClass="org.chisa.intellij.highlighting.ChisaAnnotator"/>

        <colorSettingsPage
                implementation="org.chisa.intellij.highlighting.ChisaColorSettingsPage"/>

        <projectService
                serviceImplementation="org.chisa.intellij.settings.ChisaSettings"/>

        <projectService
                serviceImplementation="org.chisa.intellij.settings.ChisaPreludeService"/>

        <projectService
                serviceImplementation="org.chisa.intellij.daemon.DaemonService"/>

        <externalAnnotator
                language="Chisa"
                implementationClass="org.chisa.intellij.daemon.DaemonAnnotator"/>

        <projectConfigurable
                parentId="language"
                instance="org.chisa.intellij.settings.ChisaSettingsConfigurable"
                id="org.chisa.intellij.settings"
                displayName="Chisa"/>

    </extensions>
</idea-plugin>
