export fn alloc(size: long): Pointer<char> {
  asm {
    in rax = 9
    in rdi = 0
    in rsi = size
    in rdx = 3
    in r10 = 34
    in r8 = -1
    in r9 = 0
    out rax = addr
    "syscall"
  }
  return addr
}

export fn free<T>(addr: Pointer<T>, size: long): void {
  asm {
    in rax = 11
    in rdi = addr
    in rsi = size
    "syscall"
  }
}

external fn ptr<T>(value: T): Pointer<T>
external fn deref<T>(ptr: Pointer<T>): T

type Pointer<T> = long
