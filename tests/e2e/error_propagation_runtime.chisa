import { Either } from "../../stdlib/Either.chisa"

fn divide(a: number, b: number): Either<number, number> {
  if (b == 0) return Either.Left(1)
  return Either.Right(a / b)
}

fn compute(a: number, b: number): Either<number, number> {
  let result = divide(a, b)!!
  return Either.Right(result * 2)
}

let result = compute(4, 0)

if (result.isOk()) {
  print(0)
} else {
  print(result.getOrElse(1))
}
