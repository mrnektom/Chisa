import { Option } from "../../stdlib/Option.chisa"

struct Address { city: number }
struct User { name: number, address: Option<Address> }

let addr = Option.Some(Address { city: 42 })
let user = Option.Some(User { name: 1, address: addr })

let name = user?.name
let city: Option<number> = user?.address?.city

print(name.getOrElse(0))
print(city.getOrElse(0))
